{
  "Jwt": {
    "Key": "YourSuperSecretKeyHere_MustBe32CharactersLong!",
    "Issuer": "AuthAPI",
    "Audience": "LibraryManagementApp"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/gateway/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/auth" }
        ]
      },
      "library-route": {
        "ClusterId": "library-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/gateway/library/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/library" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://library-auth-api-hufgbseqc3ddddh5.centralindia-01.azurewebsites.net"
          }
        }
      },
      "library-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://library-main-api-bxcpg4f7evfkebhk.centralindia-01.azurewebsites.net/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}