          "maximumCapacity",
          "name"
        ],
        "type": "object",
        "properties": {
          "libraryId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "minLength": 1,
            "type": "string"
          },
          "maximumCapacity": {
